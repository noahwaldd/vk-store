generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  pending
  paid
  canceled
}

enum UserRole {
  user
  admin
}

model User {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                 String    @unique
  name                  String?
  first_name            String?
  last_name             String?
  phone                 String?
  password_hash         String
  role                  UserRole  @default(user)
  failed_login_attempts Int       @default(0)
  locked_until          DateTime? @db.Timestamptz(6)
  disabled_at           DateTime? @db.Timestamptz(6)
  last_login_at         DateTime? @db.Timestamptz(6)
  created_at            DateTime  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  password_reset_tokens PasswordResetToken[]

  @@index([role], map: "users_role_idx")
  @@index([locked_until], map: "users_locked_until_idx")
  @@map("users")
}

model PasswordResetToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique
  expires_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at], map: "password_reset_tokens_user_created_idx")
  @@index([expires_at], map: "password_reset_tokens_expires_at_idx")
  @@map("password_reset_tokens")
}

model SiteSetting {
  key        String   @id
  value      Json
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("site_settings")
}

model OnboardingRateLimit {
  id              String   @id
  scope           String
  identifier_hash String
  count           Int      @default(0)
  reset_at        DateTime @db.Timestamptz(6)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([scope, identifier_hash, reset_at], map: "onboarding_rate_limits_scope_identifier_reset_idx")
  @@index([reset_at], map: "onboarding_rate_limits_reset_at_idx")
  @@map("onboarding_rate_limits")
}

model Category {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String    @unique
  description String?
  image_url   String?
  image_key   String?
  position    Int       @default(0)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  products    Product[]

  @@index([position, name], map: "categories_position_name_idx")
  @@map("categories")
}

model Product {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id      String?        @db.Uuid
  name             String
  slug             String         @unique
  description      String
  price            Decimal        @db.Decimal(10, 2)
  compare_at_price Decimal?       @db.Decimal(10, 2)
  stock            Int            @default(0)
  variations       Json           @default("[]")
  featured         Boolean        @default(false)
  deleted_at       DateTime?      @db.Timestamptz(6)
  created_at       DateTime       @default(now()) @db.Timestamptz(6)
  updated_at       DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  category         Category?      @relation(fields: [category_id], references: [id], onDelete: SetNull)
  images           ProductImage[]
  order_items      OrderItem[]

  @@index([category_id], map: "products_category_id_idx")
  @@index([deleted_at], map: "products_deleted_at_idx")
  @@index([featured, created_at], map: "products_featured_created_at_idx")
  @@index([category_id, created_at], map: "products_category_created_at_idx")
  @@map("products")
}

model ProductImage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id String   @db.Uuid
  url        String
  key        String?
  alt        String?
  position   Int      @default(1)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, position], map: "product_images_product_id_position_key")
  @@index([product_id], map: "product_images_product_id_idx")
  @@map("product_images")
}

model NavigationItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label      String
  href       String
  location   String   @default("primary")
  position   Int      @default(0)
  enabled    Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([location, position, label], map: "navigation_items_location_position_idx")
  @@map("navigation_items")
}

model Customer {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  email      String
  phone      String
  document   String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  orders     Order[]

  @@index([email], map: "customers_email_idx")
  @@map("customers")
}

model Order {
  id                           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id                  String?     @db.Uuid
  status                       OrderStatus @default(pending)
  total                        Decimal     @default(0) @db.Decimal(10, 2)
  created_at                   DateTime    @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  customer                     Customer?   @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  items                        OrderItem[]

  @@index([customer_id], map: "orders_customer_id_idx")
  @@index([status, created_at], map: "orders_status_created_at_idx")
  @@map("orders")
}

model OrderItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id     String   @db.Uuid
  product_id   String?  @db.Uuid
  product_name String
  quantity     Int
  unit_price   Decimal  @db.Decimal(10, 2)
  variation    String?
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  order        Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)

  @@index([order_id], map: "order_items_order_id_idx")
  @@index([product_id], map: "order_items_product_id_idx")
  @@map("order_items")
}
